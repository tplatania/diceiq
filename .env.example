# DiceIQ Environment Variables (Local Development)
# Copy this to .env and fill in real values

FLASK_ENV=development
SECRET_KEY=diceiq-dev-secret-change-in-production
VOICE_TOKEN_SECRET=diceiq-voice-dev-secret

# ElevenLabs (get from ElevenLabs dashboard)
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=
ELEVENLABS_SERVER_SECRET=

# Stripe (get from Stripe dashboard)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Cloud SQL (leave blank for local SQLite dev)
# INSTANCE_CONNECTION_NAME=psychic-medley-469413-r3:us-east1:diceiq-db
# DB_USER=postgres
# DB_PASS=
# DB_NAME=diceiq

